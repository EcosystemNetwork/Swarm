#!/bin/bash
# ecto-save — Commit vault changes from inside the container.
# Usage: ecto-save [message]

VAULT_PATH="${VAULT_PATH:-/vault}"
MESSAGE="${1:-auto: vault snapshot at $(date -u +%Y-%m-%dT%H:%M:%SZ)}"

cd "$VAULT_PATH" || exit 1

git add -A
if git diff --cached --quiet 2>/dev/null; then
    echo "No changes to commit."
    exit 0
fi

git commit -m "$MESSAGE"
echo "Vault committed: $MESSAGE"
