#!/bin/bash
# vault-search — Search the vault using ripgrep.
# Usage: vault-search <query> [max_results]

VAULT_PATH="${VAULT_PATH:-/vault}"
QUERY="$1"
MAX="${2:-20}"

if [ -z "$QUERY" ]; then
    echo "Usage: vault-search <query> [max_results]"
    exit 1
fi

rg -i -m "$MAX" --no-heading --line-number "$QUERY" "$VAULT_PATH" 2>/dev/null || echo "No results found."
